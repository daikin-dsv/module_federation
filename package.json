{
    "name": "module_federation",
    "version": "1.0.0",
    "description": "PoC to demonstrate a MFE architecture for an energy management dashboard",
    "main": "index.js",
    "scripts": {
        "dev": "npm run dev --prefix=layout & npm run dev --prefix=widgets & npm run dev --prefix=regional-app-1 & npm run dev --prefix=regional-app-2 & npm run dev --prefix=eva",
        "test": "npx playwright test",
        "test:dev": "npx playwright test --ui",
        "lint": "npm run lint:eslint && npm run lint:lit-analyzer",
        "lint:eslint": "eslint .",
        "lint:lit-analyzer": "lit-analyzer \"layout/src/**/*.{js,ts}\"",
        "format": "prettier --write .",
        "build-and-run:layout": "docker buildx build -f layout/Dockerfile --progress=plain -t layout:latest . && docker run -t -p 8080:80 layout:latest"
    },
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "^9.28.0",
        "@playwright/test": "^1.53.1",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/node": "^24.0.4",
        "dotenv": "^16.5.0",
        "eslint": "^9.28.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-lit": "^2.1.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-wc": "^3.0.1",
        "globals": "^15.14.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.0",
        "lit-analyzer": "^2.0.3",
        "prettier": "^3.5.3",
        "prettier-plugin-tailwindcss": "^0.6.12"
    },
    "workspaces": [
        "./layout",
        "./widgets",
        "./regional-app-1",
        "./eva"
    ],
    "lint-staged": {
        "**/*": "prettier --write --ignore-unknown"
    }
}
