{
    "name": "layout",
    "version": "1.0.0",
    "type": "module",
    "main": "./src/index.js",
    "exports": {
        "./components/*": "./src/components/*.js"
    },
    "scripts": {
        "dev": "rspack serve --env mode=development",
        "test": "cd .. && npx playwright test layout/tests/e2e/",
        "lint": "npm run lint:eslint && npm run lint:lit-analyzer",
        "lint:eslint": "npx eslint .",
        "lint:lit-analyzer": "npx lit-analyzer \"src/**/*.{js,ts}\"",
        "format": "npx prettier --write .",
        "build": "rspack build --env mode=production",
        "build-docker": "pwsh ../build-service.ps1 -ServiceName $npm_package_name -ServiceVersion $npm_package_version"
    },
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "@daikin-oss/dds-tokens": "^0.4.2",
        "@daikin-oss/design-system-web-components": "^1.3.2",
        "css-loader": "^7.1.2",
        "keycloak-js": "^26.2.0",
        "lit": "^3.3.0",
        "lodash": "^4.18.1"
    },
    "devDependencies": {
        "@module-federation/enhanced": "^0.8.8",
        "@rspack/cli": "^1.1.8",
        "@rspack/core": "^1.1.8",
        "@tailwindcss/postcss": "^4.0.0",
        "postcss": "^8.5.1",
        "postcss-loader": "^8.1.1",
        "tailwindcss": "^4.1.8",
        "webpack-merge": "^6.0.1"
    }
}
